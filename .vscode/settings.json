{
  "files.associations": {
    "*.css": "tailwindcss",
    "justfile": "just",
    ".env": "dotenv"
  },
  "[rust]": {
    "editor.formatOnSave": true,
    "editor.defaultFormatter": "loong-vsx.rust-analyzer"
  },
  "rust-analyzer.server.path": "rust-analyzer",
  "mise.autoDetectMiseBinPath": true,
  "mise.automaticallyTrustMiseConfigFiles": true
}
